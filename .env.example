# Apex Scanner Configuration
# Copy to .env and fill in all REQUIRED values before starting

# ============================================
# AUTHENTICATION (ALL REQUIRED - NO DEFAULTS)
# ============================================
# Admin username
ADMIN_USERNAME=admin

# Bcrypt hash of admin password. Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD_HERE', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# JWT signing secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# JWT token expiration in hours
JWT_EXPIRATION_HOURS=24

# Enable API key authentication for CI/CD pipelines
API_KEY_ENABLED=true

# Rate limiting for login attempts
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# ============================================
# CORS (REQUIRED for dashboard/frontend access)
# ============================================
# Comma-separated list of allowed origins
# Example: http://localhost:3001,https://scanner.example.com
CORS_ORIGINS=http://localhost:3001

# ============================================
# REDIS (REQUIRED)
# ============================================
REDIS_URL=redis://redis:6379/0

# Redis password (REQUIRED - used by --requirepass)
REDIS_PASSWORD=

# Redis TLS configuration (optional)
REDIS_TLS_ENABLED=false
# REDIS_TLS_CERT_PATH=/certs/redis-client.crt
# REDIS_TLS_KEY_PATH=/certs/redis-client.key
# REDIS_TLS_CA_PATH=/certs/ca.crt

# Redis memory limit
REDIS_MAX_MEMORY=2gb

# ============================================
# SERVER
# ============================================
# Public URL for report links (REQUIRED)
SERVER_HOST=http://localhost:7070

# Scanner port mapping
SCANNER_PORT=7070

# Dashboard API URL
DASHBOARD_API_URL=http://localhost:7070
DASHBOARD_PORT=3001

# ============================================
# SCANNER CONFIGURATION
# ============================================
ENABLE_GRYPE=true
ENABLE_TRIVY=true
ENABLE_SYFT=true
SCAN_TIMEOUT=900
SCAN_RESULT_TTL=2592000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# METRICS
# ============================================
ENABLE_METRICS=true
METRICS_PATH=/metrics

# ============================================
# WORKER CONFIGURATION
# ============================================
WORKER_HIGH_CONCURRENCY=8
WORKER_BATCH_CONCURRENCY=12
BATCH_WORKER_REPLICAS=2

# ============================================
# AUTOSCALER
# ============================================
MIN_WORKERS=2
MAX_WORKERS=10
SCALE_UP_THRESHOLD=10
SCALE_DOWN_THRESHOLD=2
AUTOSCALE_CHECK_INTERVAL=30

# ============================================
# CELERY FLOWER (Worker Monitoring - REQUIRED)
# ============================================
FLOWER_USER=admin
FLOWER_PASSWORD=
FLOWER_PORT=5555
